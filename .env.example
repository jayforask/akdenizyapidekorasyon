# Railway otomatik sağlar — elle girme, sadece referans için
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Güçlü rastgele bir string üret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=buraya_guclu_bir_secret_yaz

# İsteğe bağlı, varsayılan 24h
JWT_EXPIRES_IN=24h

# production veya development
NODE_ENV=production

# Railway deploy URL'ini yaz, örn: https://akdeniz-yapi.up.railway.app
ALLOWED_ORIGINS=https://antalyadiscephe.com,https://www.antalyadiscephe.com
